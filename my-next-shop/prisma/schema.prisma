datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        Int      @id @default(autoincrement())
  adminId   String   @unique @map("admin_id")
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model User {
  id                  Int      @id @default(autoincrement())
  
  // 👤 1. 기본 로그인 정보
  loginId             String   @unique @map("login_id")
  password            String
  name                String
  nickname            String?
  email               String?  @unique
  phone               String?
  
  // ✈️ 2. 구매대행 필수 배송 정보
  personalCustomsCode String?  @map("personal_customs_code")
  zipCode             String?  @map("zip_code")
  address             String?
  detailAddress       String?  @map("detail_address")
  
  // 🌟 기본 배송지 ID
  defaultAddressId    Int?     @map("default_address_id")
  
  // 💰 3. 비즈니스 로직 (결제/등급)
  cyberMoney          Int      @default(0) @map("cyber_money")
  level               String   @default("일반회원")
  addressId           String?   @map("address_id") @db.Text
  
  // 🗓️ 4. 가입 및 수정 일자
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  orders              Order[]
  addresses           Address[]

  moneyRequests MoneyRequest[]

  // 🆕 머니 로그와의 1:N 관계 추가
  moneyLogs MoneyLog[]

  @@map("users")
}

model Address {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  user                User     @relation(fields: [userId], references: [id])

  recipientName       String   @map("recipient_name")
  recipientEnglishName String? @map("recipient_english_name")
  phone               String   @map("phone")
  zipCode             String   @map("zip_code")
  address             String   @map("address")
  detailAddress       String   @map("detail_address")
  personalCustomsCode String?  @map("personal_customs_code")
  isDefault           Boolean  @default(false) @map("is_default")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("addresses")
}

enum OrderType {
  DELIVERY // 배송대행
  PURCHASE // 구매대행
}

// 2. 주문 상태 Enum (신규 추가)
enum OrderStatus {
  ALL            // 전체 내역
  BID_PENDING    // 경매 요청
  BIDDING        // 경매 낙찰 실패
  BID_SUCCESS    // 경매 낙찰 성공
  CART           // 장바구니
  FAILED         // 낙찰/구매실패
  PAID           // 상품 결제 완료
  ARRIVED        // 입고완료
  PREPARING      // 배송 준비중
  PAYMENT_REQ    // 배송비 요청
  PAYMENT_DONE   // 배송비 결제 완료
  SHIPPING       // 국제배송
}

// 3. 배송 상태 Enum (신규 추가)
enum DeliveryStatus {
  PREPARING      // 배송전
  SHIPPED        // 배송시작 (국제배송 시작)
  CUSTOMS        // 국내통관중
  LOCAL_DELIVERY // 국내배송중
  COMPLETED      // 배송완료
}

// 🌟 경매 상태값을 관리하는 Enum
enum BidStatus {
  PENDING               // 입찰 대기중
  COMPLETED             // 입찰 완료
  ADDITIONAL            // 추가 입찰 완료
}

model Order {
  // 1. 시스템 및 관계 필드
  id                  Int            @id @default(autoincrement())
  userId              Int            @map("user_id")
  user                User           @relation(fields: [userId], references: [id])

  // 2. 서비스 구분
  type                OrderType      @default(PURCHASE) @map("order_type")

  // 3. 주문 식별 및 배송 정보
  bundleId            String?        @map("bundle_id")
  orderId             String         @unique @map("order_id")
  productId           String?        @map("product_id")
  trackingNo          String?        @map("tracking_no")

  // 4. 상품 상세 정보
  productImageUrl     String?        @db.Text @map("product_image_url")
  productPrice        Int            @map("product_price") // 현재 최고가 또는 낙찰가로 활용
  productCount        Int?           @default(1)
  productName         String         @map("product_name")
  productUrl          String?        @db.Text @map("product_url")
  productOption       String?        @map("product_option")
  productRequest      String?        @map("productRequest")

  // 5. 타임스탬프 (경매 관련 추가)
  registeredAt        DateTime       @default(now()) @map("registered_at")
  receivedAt          DateTime?      @map("received_at")
  shippedAt           DateTime?      @map("shipped_at")
  auctionEndDate      DateTime?      @map("auction_end_date")       // 🌟 1. 경매 종료 시간

  // 6. 상태 관리
  serviceRequest      String?        @map("service_request")
  status              OrderStatus    @default(CART)
  deliveryStatus      DeliveryStatus @default(PREPARING) @map("delivery_status")

  // 7. 비용 및 결제 관련 (경매 정보 추가)
  purchaseFee         Int            @default(0) @map("purchase_fee")
  domesticShippingFee Int            @default(0) @map("domestic_shipping_fee")
  addressId           Int?           @map("address_id")
  secondPaymentAmount Int?           @map("second_payment_amount")
  
  myBidPrice          Int?           @default(0) @map("my_bid_price") // 🌟 2. 내 입찰 금액 (현지 통화)
  depositAmount       Int?           @default(0) @map("deposit_amount") // 🌟 3. 보증금 (원화 또는 현지 통화)
  
  // 🌟 [수정됨] 타입을 String? 에서 BidStatus? 로 변경하고 기본값을 PENDING으로 설정
  bidStatus           BidStatus?     @default(PENDING) @map("bid_status") 

  @@map("orders")
}

enum FeeType {
  TRANSFER // 송금 수수료
  AGENCY   // 대행 수수료
}

model FeeConfiguration {
  id                  Int      @id @default(autoincrement())                  // 데이터베이스 내부 관리용 고유 ID (자동 증가)
  name                String                                                  // 수수료 명칭 (예: "기본 송금 수수료", "메르카리 대행 수수료")
  feeType             FeeType  @map("fee_type")                               // 수수료 타입 구분 (예: TRANSFER, AGENCY)
  amount              Int      @default(0)                                    // 수수료 금액 (단위: 엔 ¥)
  description         String?  @db.Text                                       // 관리자 메모
  createdAt           DateTime @default(now()) @map("created_at")             // 생성 시간
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")  // 수정 시간

  @@map("fee_configurations")
}

model MercariCategory {
  id          Int      @id @default(autoincrement())  // 메루카리 고유 ID
  genreId     Int      @unique                        // 메루카리 카테고리 ID
  genreName   String                                  // 카테고리 이름
  genreLevel  Int?     @default(1)                    // 1:대분류, 2:중분류, 3:소분류...
  parentId    Int                                     // 부모 카테고리 ID
  isLeaf      Boolean  @default(false)                // 💡 최하위 카테고리 여부 저장 (기본값 false)
  updatedAt   DateTime @updatedAt                     // 데이터 갱신일 (자동)

  @@map("MercariCategory")
}

model RakutenCategory {
  id          Int      @id @default(autoincrement())  // 메루카리 고유 ID
  genreId     Int      @unique                        // 메루카리 카테고리 ID
  genreName   String                                  // 카테고리 이름
  genreLevel  Int?     @default(1)                    // 1:대분류, 2:중분류, 3:소분류...
  parentId    Int                                     // 부모 카테고리 ID
  isLeaf      Boolean  @default(false)                // 💡 최하위 카테고리 여부 저장 (기본값 false)
  updatedAt   DateTime @updatedAt                     // 데이터 갱신일 (자동)

  @@map("RakutenCategory")
}

model YahooAuctionCategory {
  id         Int      @id @default(autoincrement())
  genreId    Int      @unique
  listId     Int?     @default(0) 
  genreName  String
  genreLevel Int?     @default(1) 
  parentId   Int
  isLeaf     Boolean  @default(false)
  updatedAt  DateTime @updatedAt

  @@map("YahooAuctionCategory")
}

// 2. 머니 로그 타입 Enum 추가
enum MoneyLogType {
  CHARGE  // 충전
  USE     // 사용
  REFUND  // 환불
}

// 3. 🆕 머니 로그 모델 추가
model MoneyLog {
  id            Int           @id @default(autoincrement())
  userId        Int           @map("user_id")
  user          User          @relation(fields: [userId], references: [id])
  
  // 구분: 충전, 사용, 환불
  type          MoneyLogType
  
  // 상세 내용: "무통장 입금 충전", "주문 결제(주문번호: ...)" 등
  content       String        @db.Text
  
  // 금액: 발생한 금액 (예: 50000 또는 -35000)
  amount        Int
  
  // 잔액: 거래 직후의 최종 잔액 (이미지의 마지막 컬럼용)
  balanceAfter  Int           @map("balance_after")
  
  // 일시: 거래 발생 시간
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("money_logs")
  @@index([userId]) // 사용자별 내역 조회를 위한 인덱스
}

enum RequestType {
  CHARGE
  REFUND
}

enum RequestStatus {
  PENDING   // 대기
  APPROVED  // 승인됨
  REJECTED  // 반려됨
}

model MoneyRequest {
  id            Int           @id @default(autoincrement())
  userId        Int
  type          RequestType   // CHARGE, REFUND
  status        RequestStatus @default(PENDING)
  amount        Int
  
  // 🏦 환불 관련 상세 정보 (환불일 때만 입력됨)
  bankName      String?       // 은행명
  accountNumber String?       // 계좌번호
  accountHolder String?       // 예금주
  
  content       String?       // 추가 메모 (충전 시 입금자명 등)
  adminNote     String?       // 반려 사유 등
  createdAt     DateTime      @default(now())
  processedAt   DateTime?

  user          User          @relation(fields: [userId], references: [id])
}

model Translation {
  id        Int      @id @default(autoincrement())
  jp        String   @unique // 일본어 원문 (중복 저장 방지 및 빠른 검색)
  ko        String   // 번역된 한국어
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jp]) // 검색 성능을 위한 인덱스 추가
}