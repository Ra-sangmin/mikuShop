datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        Int      @id @default(autoincrement())
  adminId   String   @unique @map("admin_id")
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model User {
  id                  Int      @id @default(autoincrement())
  
  // 👤 1. 기본 로그인 정보
  loginId             String   @unique @map("login_id")
  password            String
  name                String
  nickname            String?
  email               String?  @unique
  phone               String?
  
  // ✈️ 2. 구매대행 필수 배송 정보
  personalCustomsCode String?  @map("personal_customs_code")
  zipCode             String?  @map("zip_code")
  address             String?
  detailAddress       String?  @map("detail_address")
  
  // 🌟 기본 배송지 ID
  defaultAddressId    Int?     @map("default_address_id")
  
  // 💰 3. 비즈니스 로직 (결제/등급)
  cyberMoney          Int      @default(0) @map("cyber_money")
  level               String   @default("일반회원")
  addressId           String?   @map("address_id") @db.Text
  
  // 🗓️ 4. 가입 및 수정 일자
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  orders              Order[]
  addresses           Address[]

  moneyRequests MoneyRequest[]

  // 🆕 머니 로그와의 1:N 관계 추가
  moneyLogs MoneyLog[]

  @@map("users")
}

model Address {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  user                User     @relation(fields: [userId], references: [id])

  recipientName       String   @map("recipient_name")
  recipientEnglishName String? @map("recipient_english_name")
  phone               String   @map("phone")
  zipCode             String   @map("zip_code")
  address             String   @map("address")
  detailAddress       String   @map("detail_address")
  personalCustomsCode String?  @map("personal_customs_code")
  isDefault           Boolean  @default(false) @map("is_default")
  
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("addresses")
}

enum OrderType {
  DELIVERY // 배송대행
  PURCHASE // 구매대행
}

// 2. 주문 상태 Enum (신규 추가)
enum OrderStatus {
  ALL            // 전체 내역
  CART           // 장바구니
  FAILED         // 구매실패
  PAID           // 상품 결제 완료
  ARRIVED        // 입고완료
  PREPARING      // 배송 준비중
  PAYMENT_REQ    // 배송비 요청
  PAYMENT_DONE   // 배송비 결제 완료
  SHIPPING       // 국제배송
}

// 3. 배송 상태 Enum (신규 추가)
enum DeliveryStatus {
  PREPARING      // 배송전
  SHIPPED        // 배송시작 (국제배송 시작)
  CUSTOMS        // 국내통관중
  LOCAL_DELIVERY // 국내배송중
  COMPLETED      // 배송완료
}

model Order {
  // 1. 시스템 및 관계 필드
  id                  Int            @id @default(autoincrement())                  // 데이터베이스 내부 관리용 고유 ID (자동 증가)
  userId              Int            @map("user_id")                                // 주문한 사용자의 고유 번호
  user                User           @relation(fields: [userId], references: [id])  // User 모델과의 참조 관계 설정

  // 2. 서비스 구분
  type                OrderType      @default(PURCHASE) @map("order_type")          // 주문 유형 (PURCHASE: 구매대행, DELIVERY: 배송대행)

  // 3. 주문 식별 및 배송 정보
  bundleId            String?        @map("bundle_id")                              // 합포장(묶음 배송) 처리를 위한 그룹 ID
  orderId             String         @unique @map("order_id")                       // 사용자에게 노출되는 고유 주문 번호 (중복 불가)
  productId           String?        @map("product_id")                             // 현지 쇼핑몰의 상품 고유 번호
  trackingNo          String?        @map("tracking_no")                            // 현지 또는 국제 운송장 번호

  // 4. 상품 상세 정보
  productImageUrl     String?        @db.Text @map("product_image_url")             // 상품 이미지 URL (긴 문자열 허용)
  productPrice        Int            @map("product_price")                          // 상품 가격 (현지 통화 기준)
  productCount        Int?           @default(1)                                    // 구매처 전달 요청사항
  productName         String         @map("product_name")                           // 상품 명칭
  productUrl          String?        @db.Text @map("product_url")                   // 상품 구매 원본 링크
  productOption       String?        @map("product_option")                         // 선택한 옵션 (사이즈, 색상 등)
  productRequest      String?        @map("productRequest")                         // 구매처 전달 요청사항

  // 5. 타임스탬프 (진행 단계별 일시)
  registeredAt        DateTime       @default(now()) @map("registered_at")          // 주문 등록 일시 (기본값: 현재 시간)
  receivedAt          DateTime?      @map("received_at")                            // 현지 물류 센터 입고 완료 일시
  shippedAt           DateTime?      @map("shipped_at")                             // 국제 배송 시작(출고) 일시

  // 6. 상태 관리
  serviceRequest      String?        @map("service_request")                        // 부가 서비스 요청 (사진 검수, 포장 보완 등)
  status              OrderStatus    @default(CART)                                 // 주문 단계 상태 (장바구니, 결제완료, 입고완료 등)
  deliveryStatus      DeliveryStatus @default(PREPARING) @map("delivery_status")    // 물류 배송 상태 (준비중, 배송중 등)

  // 7. 비용 및 결제 관련
  purchaseFee         Int            @default(0) @map("purchase_fee")               // 대행 수수료
  domesticShippingFee Int            @default(0) @map("domestic_shipping_fee")      // 일본 내 현지 배송비
  addressId           Int?           @map("address_id")                             // 배송지 주소 ID
  secondPaymentAmount Int?           @map("second_payment_amount")                  // 2차 결제 금액 (국제 배송비 등 추가 비용)

  @@map("orders") // 실제 데이터베이스 테이블 이름을 "orders"로 지정
}

enum FeeType {
  TRANSFER // 송금 수수료
  AGENCY   // 대행 수수료
}

model FeeConfiguration {
  id                  Int      @id @default(autoincrement())                  // 데이터베이스 내부 관리용 고유 ID (자동 증가)
  name                String                                                  // 수수료 명칭 (예: "기본 송금 수수료", "메르카리 대행 수수료")
  feeType             FeeType  @map("fee_type")                               // 수수료 타입 구분 (예: TRANSFER, AGENCY)
  amount              Int      @default(0)                                    // 수수료 금액 (단위: 엔 ¥)
  description         String?  @db.Text                                       // 관리자 메모
  createdAt           DateTime @default(now()) @map("created_at")             // 생성 시간
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")  // 수정 시간

  @@map("fee_configurations")
}

model MercariCategory {
  id          Int      @id @default(autoincrement())  // 메루카리 고유 ID
  genreId     Int      @unique                        // 메루카리 카테고리 ID
  genreName   String                                  // 카테고리 이름
  genreLevel  Int?     @default(1)                    // 1:대분류, 2:중분류, 3:소분류...
  parentId    Int                                     // 부모 카테고리 ID
  isLeaf      Boolean  @default(false)                // 💡 최하위 카테고리 여부 저장 (기본값 false)
  updatedAt   DateTime @updatedAt                     // 데이터 갱신일 (자동)

  @@map("MercariCategory")
}

model RakutenCategory {
  id          Int      @id @default(autoincrement())  // 메루카리 고유 ID
  genreId     Int      @unique                        // 메루카리 카테고리 ID
  genreName   String                                  // 카테고리 이름
  genreLevel  Int?     @default(1)                    // 1:대분류, 2:중분류, 3:소분류...
  parentId    Int                                     // 부모 카테고리 ID
  isLeaf      Boolean  @default(false)                // 💡 최하위 카테고리 여부 저장 (기본값 false)
  updatedAt   DateTime @updatedAt                     // 데이터 갱신일 (자동)

  @@map("RakutenCategory")
}

// 2. 머니 로그 타입 Enum 추가
enum MoneyLogType {
  CHARGE  // 충전
  USE     // 사용
  REFUND  // 환불
}

// 3. 🆕 머니 로그 모델 추가
model MoneyLog {
  id            Int           @id @default(autoincrement())
  userId        Int           @map("user_id")
  user          User          @relation(fields: [userId], references: [id])
  
  // 구분: 충전, 사용, 환불
  type          MoneyLogType
  
  // 상세 내용: "무통장 입금 충전", "주문 결제(주문번호: ...)" 등
  content       String        @db.Text
  
  // 금액: 발생한 금액 (예: 50000 또는 -35000)
  amount        Int
  
  // 잔액: 거래 직후의 최종 잔액 (이미지의 마지막 컬럼용)
  balanceAfter  Int           @map("balance_after")
  
  // 일시: 거래 발생 시간
  createdAt     DateTime      @default(now()) @map("created_at")

  @@map("money_logs")
  @@index([userId]) // 사용자별 내역 조회를 위한 인덱스
}

enum RequestType {
  CHARGE
  REFUND
}

enum RequestStatus {
  PENDING   // 대기
  APPROVED  // 승인됨
  REJECTED  // 반려됨
}

model MoneyRequest {
  id            Int           @id @default(autoincrement())
  userId        Int
  type          RequestType   // CHARGE, REFUND
  status        RequestStatus @default(PENDING)
  amount        Int
  
  // 🏦 환불 관련 상세 정보 (환불일 때만 입력됨)
  bankName      String?       // 은행명
  accountNumber String?       // 계좌번호
  accountHolder String?       // 예금주
  
  content       String?       // 추가 메모 (충전 시 입금자명 등)
  adminNote     String?       // 반려 사유 등
  createdAt     DateTime      @default(now())
  processedAt   DateTime?

  user          User          @relation(fields: [userId], references: [id])
}

model Translation {
  id        Int      @id @default(autoincrement())
  jp        String   @unique // 일본어 원문 (중복 저장 방지 및 빠른 검색)
  ko        String   // 번역된 한국어
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jp]) // 검색 성능을 위한 인덱스 추가
}